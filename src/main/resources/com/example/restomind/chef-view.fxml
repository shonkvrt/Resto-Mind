<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.restomind.ChefController"
      style="-fx-background-color: #2c3e50;">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label fx:id="statusLabel" text="Kitchen Management System - RestoMind"
           style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

    <StackPane VBox.vgrow="ALWAYS">

        <VBox fx:id="workPlanArea" spacing="15" alignment="CENTER">
            <Button text="Generate AI Work Plan" onAction="#onStartDayClick"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10 20;"/>

            <ListView fx:id="workPlanList" prefHeight="350" maxWidth="500"
                      style="-fx-background-radius: 10; -fx-font-size: 14px; -fx-control-inner-background: #ffffff; -fx-text-fill: #000000;"/>

            <Button text="Finish Prep &amp; Start Service" onAction="#onFinishPrepClick"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10 20;"/>
        </VBox>

        <VBox fx:id="ordersArea" spacing="15" alignment="TOP_CENTER" visible="false">
            <Label text="Pending Orders:" style="-fx-text-fill: #ecf0f1; -fx-font-size: 18px;"/>

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="orders" spacing="15" alignment="TOP_CENTER">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </VBox>
            </ScrollPane>

            <Button text="End Day &amp; Save Data" onAction="#onCloseDayClick"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>

        </VBox>

    </StackPane>
</VBox>