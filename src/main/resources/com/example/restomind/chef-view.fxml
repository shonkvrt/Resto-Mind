<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.restomind.ChefController"
      style="-fx-background-color: #2c3e50;">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- כותרת סטטוס -->
    <Label fx:id="statusLabel" text="מערכת ניהול מטבח - RestoMind"
           style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

    <StackPane VBox.vgrow="ALWAYS">

        <!-- מסך א': שלב ההכנות - שיניתי ל-workPlanArea לפי הקוד שלך -->
        <VBox fx:id="workPlanArea" spacing="15" alignment="CENTER">
            <Button text="הפקת תוכנית עבודה AI" onAction="#onStartDayClick"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10 20;"/>

            <ListView fx:id="workPlanList" prefHeight="350" maxWidth="500"
                      style="-fx-background-radius: 10; -fx-font-size: 14px;"/>

            <Button text="סיום הכנות ותחילת סרביס" onAction="#onFinishPrepClick"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10 20;"/>
        </VBox>

        <!-- מסך ב': שלב קבלת ההזמנות - שיניתי ל-ordersArea -->
        <VBox fx:id="ordersArea" spacing="15" alignment="TOP_CENTER" visible="false">
            <Label text="הזמנות ממתינות להכנה:" style="-fx-text-fill: #ecf0f1; -fx-font-size: 18px;"/>

            <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;">
                <!-- המכולה של ההזמנות עצמן - שיניתי ל-orders לפי הקוד שלך -->
                <VBox fx:id="orders" spacing="15" alignment="TOP_CENTER">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </VBox>
            </ScrollPane>
        </VBox>

    </StackPane>
</VBox>